# Supabase — https://supabase.com/dashboard → Project → Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Backend API URL
# Development: http://localhost:8787
# Production: https://neoa-api-production.your-subdomain.workers.dev (or your custom domain)
VITE_API_URL=http://localhost:8787

# Paystack — https://dashboard.paystack.com → Settings → API Keys
VITE_PAYSTACK_PUBLIC_KEY=pk_test_YOUR_KEY_HERE

# PostHog Analytics — https://app.posthog.com → Project → Settings
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Sentry Error Monitoring — https://sentry.io → Project → Settings → Client Keys
VITE_SENTRY_DSN=
